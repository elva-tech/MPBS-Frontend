NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/mpbs
JWT_SECRET=your-production-secret-key-min-32-chars-required
JWT_EXPIRY=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:5175
CORS_CREDENTIALS=true
SOCIETY_FIXED_RATE=45
AWS_REGION=us-east-1
AWS_S3_BUCKET=mpbs-dev-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DB_CONNECT_MAX_RETRIES=30
DB_CONNECT_RETRY_DELAY_MS=2500
DB_QUERY_TIMEOUT_MS=30000
DEV_RESTART_DELAY_MS=5000
UPLOAD_MAX_MB=50
LOG_LEVEL=info
REQUEST_LOG_SAMPLE_RATE=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX=30
